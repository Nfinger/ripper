{
  "name": "symphony",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "symphony": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:release": "rm -rf dist-release && mkdir -p dist-release && pnpm build && pnpm pack --pack-destination dist-release"
  },
  "dependencies": {
    "js-yaml": "4.1.0",
    "liquidjs": "10.21.1",
    "pino": "9.5.0",
    "playwright": "1.49.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "pnpm": {
    "minimumReleaseAge": 4320,
    "minimumReleaseAgeExclude": []
  }
}
