# Symphony/Ripper env file. Copy to `.env` and fill in real local values.
# Loaded by node via `--env-file=.env` at daemon startup when you choose to use an env file.
# Do not commit `.env`.

# Linear profiles
LINEAR_API_KEY=replace-with-linear-api-key

# Jira profiles
TIMEHAWK_JIRA_EMAIL=replace-with-jira-account-email
TIMEHAWK_JIRA_TOKEN=replace-with-jira-api-token

# Optional. Override the symphony log level (debug | info | warn | error).
# SYMPHONY_LOG_LEVEL=info
