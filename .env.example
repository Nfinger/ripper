# Symphony env file. Copy to `.env` and fill in real values.
# Loaded by node via `--env-file=.env` at daemon startup.

# Linear (covers the rhema and market-savvy profiles)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jira (TimeHawk profile)
TIMEHAWK_JIRA_EMAIL=nate@timehawk.ai
TIMEHAWK_JIRA_TOKEN=ATATT3xFf...

# Optional. Override the symphony log level (debug | info | warn | error).
# SYMPHONY_LOG_LEVEL=info
